{
  "name": "qa-radar",
  "version": "3.0.1",
  "description": "Scanner de qualidade para detectar erros JavaScript, HTTP e de rede em aplicações web.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qa-radar": "dist/index.js",
    "qa-radar-web": "dist/web.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "BENCHMARKS.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "web": "tsx src/web.ts",
    "web:start": "node dist/web.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "node --import tsx --test tests/cli.test.ts tests/history.test.ts tests/quality.test.ts tests/reporters.test.ts tests/scanner-evidence.test.ts tests/schema.test.ts tests/server.test.ts tests/sitemap.test.ts tests/web-page.test.ts",
    "test:integration": "node --import tsx --test tests/scanner.integration.test.ts tests/suite.integration.test.ts tests/web.integration.test.ts",
    "benchmark:sitemap": "node --import tsx scripts/benchmark-sitemap.ts",
    "check": "npm run typecheck && npm test && npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "qa",
    "playwright",
    "smoke-test",
    "web-testing",
    "quality-gate"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
